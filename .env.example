# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram API через Cloudflare Worker прокси
# Worker: https://telegram-bot-proxy.d-megabyte.workers.dev
TELEGRAM_API_BASE_URL=https://telegram-bot-proxy.d-megabyte.workers.dev/bot

# N8N WF1 webhook (gateway-agent → MCP novostroym)
N8N_URL=https://n8n.it-system.io
N8N_ENDPOINT=/webhook/openrouter-direct-test
N8N_TOKEN=your_n8n_api_key

# OpenRouter (для ответчика)
OPENROUTER_API_KEY=your_openrouter_api_key
